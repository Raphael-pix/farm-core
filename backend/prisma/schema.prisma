generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Farm {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  inviteCode  String   @unique @map("invite_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users            User[]
  fields           Field[]
  notifications    Notification[]
  animals          Animal[]
  animalIdentities AnimalIdentity[]
  medicalRecords   MedicalRecord[]
  breedingEvents   BreedingEvent[]
  mortalities      Mortality[]
  feeds            Feed[]
  feedInventories  FeedInventory[]
  feedConsumptions FeedConsumption[]
  feedAllocations  FeedAllocation[]
  tasks            Task[]
  taskCompletions  TaskCompletion[]
  taskTemplates    TaskTemplate[]

  @@index([slug])
  @@map("farms")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  role      Role     @default(AGENT)
  fullName  String?  @map("full_name")
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  farm   Farm?   @relation(fields: [farmId], references: [id], onDelete: SetNull)
  farmId String? @map("farm_id") @db.Uuid

  fieldImages           FieldImage[]
  fieldUpdates          FieldUpdate[]     @relation("AgentUpdates")
  assignedFields        Field[]           @relation("AgentFields")
  updatedFields         Field[]           @relation("FieldUpdatedBy")
  notifications         Notification[]
  animalsCreated        Animal[]          @relation("AnimalCreatedBy")
  animalsUpdated        Animal[]          @relation("AnimalUpdatedBy")
  medicalRecords        MedicalRecord[]   @relation("MedicalRecordRecordedBy")
  breedingEvents        BreedingEvent[]   @relation("BreedingEventRecordedBy")
  mortalities           Mortality[]       @relation("MortalityRecordedBy")
  feedCreated           Feed[]            @relation("FeedCreatedBy")
  feedUpdated           Feed[]            @relation("FeedUpdatedBy")
  feedInventoryUpdated  FeedInventory[]   @relation("FeedInventoryUpdatedBy")
  feedConsumptions      FeedConsumption[] @relation("FeedConsumptionRecordedBy")
  tasksAssigned         Task[]            @relation("TaskAssignedTo")
  tasksCreated          Task[]            @relation("TaskCreatedBy")
  tasksUpdated          Task[]            @relation("TaskUpdatedBy")
  taskCompletions       TaskCompletion[]  @relation("TaskCompletedBy")
  taskTemplatesAssigned TaskTemplate[]    @relation("TaskTemplateAssignedTo")

  @@index([role])
  @@map("users")
}

model Location {
  id        String   @id @default(uuid()) @db.Uuid
  county    String
  subCounty String?  @map("sub_county")
  ward      String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  field   Field?
  animals Animal[]

  @@index([county])
  @@index([county], map: "idx_locations_county")
  @@map("locations")
}

model Field {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  cropType      String    @map("crop_type")
  plantingDate  DateTime  @map("planting_date")
  currentStage  CropStage @default(PLANTED) @map("current_stage")
  description   String?
  areaSize      Float?    @map("area_size")
  coverImageUrl String?   @map("cover_image_url")
  lastUpdatedAt DateTime? @map("last_updated_at")
  isArchived    Boolean   @default(false) @map("is_archived")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  agentId String? @map("agent_id") @db.Uuid
  agent   User?   @relation("AgentFields", fields: [agentId], references: [id])

  locationId String   @unique @map("location_id") @db.Uuid
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  updatedById String? @map("updated_by_id") @db.Uuid
  updatedBy   User?   @relation("FieldUpdatedBy", fields: [updatedById], references: [id])

  farm   Farm   @relation(fields: [farmId], references: [id])
  farmId String @map("farm_id") @db.Uuid

  images        FieldImage[]
  updates       FieldUpdate[]
  notifications Notification[]
  tasks         Task[]

  @@index([agentId])
  @@index([agentId, isArchived])
  @@index([currentStage])
  @@index([isArchived])
  @@index([plantingDate])
  @@index([lastUpdatedAt])
  @@index([agentId], map: "idx_fields_agent_active", where: raw("(is_archived = false)"))
  @@index([currentStage], map: "idx_fields_stage_active", where: raw("(is_archived = false)"))
  @@map("fields")
}

model FieldUpdate {
  id         String    @id @default(uuid()) @db.Uuid
  stage      CropStage
  notes      String?
  imageUrl   String?   @map("image_url")
  observedAt DateTime  @map("observed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  agentId String @map("agent_id") @db.Uuid
  agent   User   @relation("AgentUpdates", fields: [agentId], references: [id], onDelete: Cascade)

  fieldId String @map("field_id") @db.Uuid
  field   Field  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@index([fieldId, observedAt(sort: Desc)])
  @@index([agentId])
  @@index([observedAt])
  @@index([fieldId, observedAt(sort: Desc)], map: "idx_field_updates_field_observed")
  @@map("field_updates")
}

model FieldImage {
  id        String   @id @default(uuid()) @db.Uuid
  url       String
  caption   String?
  createdAt DateTime @default(now()) @map("created_at")

  fieldId String @map("field_id") @db.Uuid
  field   Field  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  uploadedById String? @map("uploaded_by_id") @db.Uuid
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  @@index([fieldId])
  @@index([uploadedById])
  @@map("field_images")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fieldId String? @map("field_id") @db.Uuid
  field   Field?  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([userId, farmId, createdAt(sort: Desc)])
  @@index([userId, isRead])
  @@index([farmId, createdAt(sort: Desc)])
  @@map("notifications")
}

model Animal {
  id      String  @id @default(uuid()) @db.Uuid
  name    String?
  species Species
  breed   String?

  sex             Sex
  dateOfBirth     DateTime?    @map("date_of_birth")
  acquiredDate    DateTime?    @map("acquired_date")
  status          AnimalStatus @default(ACTIVE)
  statusChangedAt DateTime?    @map("status_changed_at")
  statusReason    String?      @map("status_reason")

  color      String?
  weight     Float?
  weightUnit String? @default("kg") @map("weight_unit")
  height     Float?
  notes      String?

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  locationId String?   @map("location_id") @db.Uuid
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  maleParentId String? @map("male_parent_id") @db.Uuid
  maleParent   Animal? @relation("OffspringFromMale", fields: [maleParentId], references: [id], onDelete: SetNull)

  femaleParentId String? @map("female_parent_id") @db.Uuid
  femaleParent   Animal? @relation("OffspringFromFemale", fields: [femaleParentId], references: [id], onDelete: SetNull)

  maleOffspring   Animal[] @relation("OffspringFromMale")
  femaleOffspring Animal[] @relation("OffspringFromFemale")

  createdById String?  @map("created_by_id") @db.Uuid
  createdBy   User?    @relation("AnimalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")

  updatedById String?  @map("updated_by_id") @db.Uuid
  updatedBy   User?    @relation("AnimalUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt @map("updated_at")

  identities           AnimalIdentity[]
  medicalRecords       MedicalRecord[]
  breedingEvents       BreedingEvent[]
  breedingEventsMale   BreedingEvent[]  @relation("BreedingEventMale")
  breedingEventsFemale BreedingEvent[]  @relation("BreedingEventFemale")
  mortalities          Mortality[]
  feedAllocations      FeedAllocation[]
  tasks                Task[]

  @@index([farmId])
  @@index([farmId, status])
  @@index([farmId, species])
  @@index([farmId, createdAt])
  @@map("animals")
}

model AnimalIdentity {
  id    String             @id @default(uuid()) @db.Uuid
  type  AnimalIdentityType
  value String

  isActive  Boolean   @default(true) @map("is_active")
  issuedAt  DateTime  @map("issued_at")
  revokedAt DateTime? @map("revoked_at")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@unique([farmId, type, value])
  @@index([farmId, animalId])
  @@index([farmId, type, value])
  @@map("animal_identities")
}

model MedicalRecord {
  id     String           @id @default(uuid()) @db.Uuid
  type   MedicalEventType
  status MedicalStatus    @default(COMPLETED)

  title       String
  description String?
  diagnosis   String?
  treatment   String?

  medication String?
  dosage     Float?
  doseUnit   String?
  frequency  String?
  duration   String?

  veterinarianName String? @map("veterinarian_name")
  clinicName       String? @map("clinic_name")

  scheduledFor DateTime? @map("scheduled_for")
  completedAt  DateTime? @map("completed_at")

  estimatedCost Float? @map("estimated_cost")
  actualCost    Float? @map("actual_cost")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  recordedById String? @map("recorded_by_id") @db.Uuid
  recordedBy   User?   @relation("MedicalRecordRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([farmId, animalId])
  @@index([farmId, type])
  @@index([farmId, createdAt])
  @@index([farmId, status])
  @@map("medical_records")
}

model BreedingEvent {
  id     String         @id @default(uuid()) @db.Uuid
  status BreedingStatus @default(PLANNED)

  plannedDate       DateTime? @map("planned_date")
  matedDate         DateTime? @map("mated_date")
  expectedBirthDate DateTime? @map("expected_birth_date")
  actualBirthDate   DateTime? @map("actual_birth_date")

  numberOfOffspring Int?    @map("number_of_offspring")
  offspringNotes    String? @map("offspring_notes")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  maleId String @map("male_id") @db.Uuid
  male   Animal @relation("BreedingEventMale", fields: [maleId], references: [id], onDelete: Cascade)

  femaleId String @map("female_id") @db.Uuid
  female   Animal @relation("BreedingEventFemale", fields: [femaleId], references: [id], onDelete: Cascade)

  recordedById String? @map("recorded_by_id") @db.Uuid
  recordedBy   User?   @relation("BreedingEventRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  animal   Animal? @relation(fields: [animalId], references: [id])
  animalId String? @db.Uuid

  @@index([farmId, maleId])
  @@index([farmId, femaleId])
  @@index([farmId, status])
  @@index([farmId, actualBirthDate])
  @@map("breeding_events")
}

model Mortality {
  id           String     @id @default(uuid()) @db.Uuid
  dateOfDeath  DateTime   @map("date_of_death")
  cause        DeathCause
  causeDetails String?    @map("cause_details")

  location String?
  age      String?

  postMortemNotes String? @map("post_mortem_notes")
  bodyDisposal    String? @map("body_disposal")

  createdAt DateTime @default(now()) @map("created_at")

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String @map("animal_id") @db.Uuid
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  recordedById String? @map("recorded_by_id") @db.Uuid
  recordedBy   User?   @relation("MortalityRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([farmId, animalId])
  @@index([farmId, dateOfDeath])
  @@index([farmId, cause])
  @@map("mortalities")
}

model Feed {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  type        FeedType
  description String?
  unit        FeedUnit

  costPerUnit Float?
  supplier    String?

  lowStockThreshold Float?
  criticalThreshold Float?

  isActive Boolean @default(true) @map("is_active")

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  createdById String?  @map("created_by_id") @db.Uuid
  createdBy   User?    @relation("FeedCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")

  updatedById String?  @map("updated_by_id") @db.Uuid
  updatedBy   User?    @relation("FeedUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt @map("updated_at")

  inventories  FeedInventory[]
  consumptions FeedConsumption[]
  allocations  FeedAllocation[]

  @@index([farmId])
  @@index([farmId, isActive])
  @@map("feeds")
}

model FeedInventory {
  id           String   @id @default(uuid()) @db.Uuid
  currentLevel Float    @map("current_level")
  unit         FeedUnit

  location          String?
  lastUpdatedAt     DateTime? @map("last_updated_at")
  lastUpdatedReason String?   @map("last_updated_reason")

  status InventoryStatus @default(ADEQUATE)

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  feedId String @map("feed_id") @db.Uuid
  feed   Feed   @relation(fields: [feedId], references: [id], onDelete: Cascade)

  updatedById String?  @map("updated_by_id") @db.Uuid
  updatedBy   User?    @relation("FeedInventoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([farmId, feedId])
  @@index([farmId, status])
  @@index([farmId, currentLevel])
  @@map("feed_inventories")
}

model FeedConsumption {
  id String @id @default(uuid()) @db.Uuid

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  feedId String @map("feed_id") @db.Uuid
  feed   Feed   @relation(fields: [feedId], references: [id], onDelete: Cascade)

  quantity Float
  unit     FeedUnit

  observedAt DateTime @map("observed_at")
  createdAt  DateTime @default(now()) @map("created_at")

  notes       String?
  temperature Float?

  animalAllocations FeedAllocation[]

  recordedById String? @map("recorded_by_id") @db.Uuid
  recordedBy   User?   @relation("FeedConsumptionRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([farmId, feedId])
  @@index([farmId, observedAt(sort: Desc)])
  @@index([feedId, observedAt])
  @@map("feed_consumptions")
}

model FeedAllocation {
  id String @id @default(uuid()) @db.Uuid

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  consumptionId String          @map("consumption_id") @db.Uuid
  consumption   FeedConsumption @relation(fields: [consumptionId], references: [id], onDelete: Cascade)

  feedId String @map("feed_id") @db.Uuid
  feed   Feed   @relation(fields: [feedId], references: [id], onDelete: Cascade)

  animalId String? @map("animal_id") @db.Uuid
  animal   Animal? @relation(fields: [animalId], references: [id], onDelete: SetNull)

  quantityAllocated Float @map("quantity_allocated")

  notes String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([farmId, animalId])
  @@index([consumptionId])
  @@map("feed_allocations")
}

model Task {
  id String @id @default(uuid()) @db.Uuid

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  type     TaskType
  status   TaskStatus   @default(PENDING)
  priority TaskPriority @default(NORMAL)

  title       String
  description String?

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  dueDate             DateTime @map("due_date")
  dueDateNotification Boolean  @default(true) @map("due_date_notification")

  startDate   DateTime? @map("start_date")
  completedAt DateTime? @map("completed_at")
  missedAt    DateTime? @map("missed_at")

  animalId String? @map("animal_id") @db.Uuid
  animal   Animal? @relation(fields: [animalId], references: [id], onDelete: SetNull)

  fieldId String? @map("field_id") @db.Uuid
  field   Field?  @relation(fields: [fieldId], references: [id], onDelete: SetNull)

  medicalRecordId String? @map("medical_record_id") @db.Uuid
  breedingEventId String? @map("breeding_event_id") @db.Uuid

  isRecurring       Boolean   @default(false) @map("is_recurring")
  recurrencePattern String?   @map("recurrence_pattern")
  recurrenceEndDate DateTime? @map("recurrence_end_date")

  notes           String?
  completionNotes String? @map("completion_notes")

  createdById String?  @map("created_by_id") @db.Uuid
  createdBy   User?    @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")

  updatedById String?  @map("updated_by_id") @db.Uuid
  updatedBy   User?    @relation("TaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt @map("updated_at")

  completions TaskCompletion[]

  @@index([farmId])
  @@index([farmId, status])
  @@index([farmId, dueDate])
  @@index([assignedToId, status])
  @@index([farmId, type, status])
  @@index([animalId])
  @@index([fieldId])
  @@map("tasks")
}

model TaskCompletion {
  id String @id @default(uuid()) @db.Uuid

  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  taskId String @map("task_id") @db.Uuid
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  completedAt DateTime @map("completed_at")

  notes    String?
  evidence String?

  completedById String @map("completed_by_id") @db.Uuid
  completedBy   User   @relation("TaskCompletedBy", fields: [completedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([farmId, taskId])
  @@index([taskId])
  @@index([completedAt])
  @@map("task_completions")
}

model TaskTemplate {
  id     String @id @default(uuid()) @db.Uuid
  farmId String @map("farm_id") @db.Uuid
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        TaskType
  priority    TaskPriority @default(NORMAL)

  defaultAssignedToId String? @map("default_assigned_to_id") @db.Uuid
  defaultAssignedTo   User?   @relation("TaskTemplateAssignedTo", fields: [defaultAssignedToId], references: [id], onDelete: SetNull)

  recurrencePattern String  @map("recurrence_pattern")
  daysOfWeek        String? @map("days_of_week")
  dayOfMonth        Int?    @map("day_of_month")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([farmId, isActive])
  @@map("task_templates")
}

enum Role {
  ADMIN
  AGENT
}

enum CropStage {
  PLANTED
  GROWING
  READY
  HARVESTED
}

enum NotificationType {
  FIELD_AT_RISK
  FIELD_COMPLETED
  FIELD_ASSIGNED
}

enum Species {
  CATTLE
  SHEEP
  GOATS
  PIGS
  POULTRY
  FISH
  BEEHIVE
  OTHER
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

enum AnimalStatus {
  ACTIVE
  SOLD
  DEAD
  MISSING
  ARCHIVED
}

enum AnimalIdentityType {
  QR_CODE
  RFID_TAG
  EAR_TAG
  TATTOO
  MICROCHIP
  NAME
  MANUAL_ID
}

enum MedicalEventType {
  ILLNESS
  TREATMENT
  MEDICATION
  VACCINATION
  HEALTH_CHECK
  SURGERY
  DEATH
  INJURY
  QUARANTINE
}

enum MedicalStatus {
  SCHEDULED
  COMPLETED
  MISSED
  CANCELLED
}

enum BreedingStatus {
  PLANNED
  MATED
  PREGNANT
  DELIVERED
  FAILED
  MISCARRIAGE
}

enum DeathCause {
  DISEASE
  INJURY
  AGE
  PREDATION
  ACCIDENT
  UNKNOWN
  EUTHANASIA
  OTHER
}

enum FeedType {
  GRAIN
  HAY
  SILAGE
  PELLETS
  SUPPLEMENTS
  PASTURE
  OTHER
}

enum FeedUnit {
  KG
  TONNES
  LITRES
  BAGS
  BALES
  BUNDLES
  OTHER
}

enum InventoryStatus {
  ADEQUATE
  LOW
  CRITICAL
  OUT_OF_STOCK
  OVERSTOCKED
}

enum TaskType {
  VACCINATION
  HEALTH_CHECK
  MEDICATION
  BREEDING_MONITOR
  LABOR_MONITOR

  FEED_PROCUREMENT
  FEED_DISTRIBUTION
  INVENTORY_CHECK

  FIELD_INSPECTION
  CROP_HARVEST
  PLANTING

  MAINTENANCE
  CLEANING
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  MISSED
  OVERDUE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}
